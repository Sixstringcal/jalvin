{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "rootDir": "src",
    "outDir": "dist",
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM"],
    "exactOptionalPropertyTypes": false
  },
  "include": ["src/**/*"],
  "exclude": ["dist", "node_modules"]
}
