{
  "name": "jalvin-vscode",
  "displayName": "Jalvin Language Support",
  "description": "Syntax highlighting for the Jalvin language (.jalvin files)",
  "version": "0.1.0",
  "publisher": "jalvin",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "jalvin",
        "aliases": ["Jalvin", "jalvin"],
        "extensions": [".jalvin"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "jalvin",
        "scopeName": "source.jalvin",
        "path": "./syntaxes/jalvin.tmLanguage.json"
      }
    ]
  }
}
