{
  "name": "vscode-jalvin",
  "displayName": "Jalvin",
  "description": "Syntax highlighting and formatting for the Jalvin programming language",
  "version": "1.0.0",
  "publisher": "jalvin-lang",
  "engines": {
    "vscode": "^1.75.0"
  },
  "main": "./dist/extension.js",
  "activationEvents": [
    "onLanguage:jalvin"
  ],
  "categories": [
    "Programming Languages",
    "Formatters"
  ],
  "contributes": {
    "languages": [
      {
        "id": "jalvin",
        "aliases": [
          "Jalvin",
          "jalvin"
        ],
        "extensions": [
          ".jalvin"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "jalvin",
        "scopeName": "source.jalvin",
        "path": "./syntaxes/jalvin.tmLanguage.json"
      }
    ]
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "package": "vsce package",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/vscode": "^1.75.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  }
}
